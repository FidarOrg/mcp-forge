{
  "name": "{{projectName}}",
  "version": "0.1.0",
  "private": true,
  "description": "MCP server generated by mcpfoundry.",
  "type": "module",
  "bin": {
    "{{projectName}}": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "tools": "tsx src/list-tools.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.4.0",
    "zod": "^3.23.8"{{#if isHttp}},
    "express": "^4.19.2"{{/if}}{{#if secure}},
    "jsonwebtoken": "^9.0.2"{{/if}}{{#if isSqlite}},
    "better-sqlite3": "^11.8.1"{{/if}}{{#if (eq provider "postgres")}},
    "pg": "^8.11.5"{{/if}}
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "tsx": "^4.16.0",
    "@types/node": "^20.14.0"{{#if isHttp}},
    "@types/express": "^4.17.21"{{/if}}{{#if secure}},
    "@types/jsonwebtoken": "^9.0.6"{{/if}}{{#if isSqlite}},
    "@types/better-sqlite3": "^7.6.11"{{/if}}{{#if (eq provider "postgres")}},
    "@types/pg": "^8.11.6"{{/if}}
  }
}
