import { z } from "zod";
{{#if isSqlite}}import { db } from "./db.js";
{{/if}}{{#if secure}}import { applyCanary } from "./security.js";
{{/if}}
/**
 * Tools generated by mcpfoundry from a {{sourceType}} source.
 * Each tool ships a Zod schema (parameter hardening, always on) and a working
 * handler ({{#if isSqlite}}parameterised SQL{{else}}{{#if isDatabase}}TODO stub{{else}}HTTP call to BASE_URL{{/if}}{{/if}}).
 */
export interface McpTool {
  name: string;
  description: string;
  schema: Record<string, z.ZodTypeAny>;
  handler: (args: any) => Promise<{ content: { type: "text"; text: string }[] }>;
}

export const tools: McpTool[] = [
{{#each tools}}
  {
    name: {{json this.name}},
    description: {{json this.description}},
    schema: {
{{#each this.params}}
      {{this.name}}: {{{zodType this}}},
{{/each}}
    },
    handler: async (args) => {
{{{this.handlerBody}}}
    },
  },
{{/each}}
];
